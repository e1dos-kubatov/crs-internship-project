# Environment variables for local development (copy to .env or set in terminal)

# Google: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:
# Local: http://localhost:8081/login/oauth2/code/google
# Render: https://your-render-service.onrender.com/login/oauth2/code/google
GOOGLE_CLIENT_ID=oauth-not-configured
GOOGLE_CLIENT_SECRET=oauth-not-configured

# App URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8081
PORT=8081

# DB
DB_URL=jdbc:postgresql://localhost:5432/car-rental-system
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# Initial admin user. Use a strong password in production.
APP_ADMIN_NAME=System Admin
APP_ADMIN_EMAIL=admin@carrental.local
APP_ADMIN_PASSWORD=Admin123!

# JWT. Use a long random secret in production.
JWT_SECRET=change-this-secret-key-to-a-64-character-minimum-value-for-production-use-123456
JWT_EXPIRATION=86400000

# Production Neon example:
# DB_URL=jdbc:postgresql://your-neon-host.neon.tech:5432/neondb?sslmode=require
# DB_USERNAME=neondb_owner
# DB_PASSWORD=your_neon_password

# Run with: setx GOOGLE_CLIENT_ID=... (persistent) or set GOOGLE_CLIENT_ID=... && mvn spring-boot:run (session)

