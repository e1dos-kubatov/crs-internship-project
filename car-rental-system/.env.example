# Database
DB_URL=jdbc:postgresql://postgres:5432/car-rental-system
DB_USERNAME=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your-super-secret-jwt-key-min64charsabcdefghijklmnopqrstuvwxyz1234567890ABCD
JWT_EXPIRATION=86400000

# Admin Seed
APP_ADMIN_NAME=Super Admin
APP_ADMIN_EMAIL=superadmin@carrental.com
APP_ADMIN_PASSWORD=Super123!

# OAuth2 (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-secret

